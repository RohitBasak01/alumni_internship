# Staging Environment Variables
# Copy this file to .env.staging and fill in the values

# Server Configuration
PORT=5000
NODE_ENV=staging
LOG_LEVEL=debug

# Database Configuration
MONGODB_URI=mongodb://staging-mongo:27017/alumni-staging
CENTRAL_MONGODB_URI=mongodb://staging-mongo:27017/alumni-central-staging
TENANT_MONGODB_BASE_URI=
TENANT_DATABASE_MODE=shared
DEFAULT_TENANT_ISOLATION_MODE=shared

# JWT & Authentication
JWT_SECRET=staging-jwt-secret-change-this
JWT_REFRESH_SECRET=staging-refresh-secret-change-this
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
AUTH_COOKIE_DOMAIN=.staging.alumni.example.com

# Application URLs
CLIENT_URL=https://staging.alumni.example.com
FRONTEND_URL=https://staging.alumni.example.com
CORS_ALLOWED_ORIGINS=https://staging.alumni.example.com

# Security & Rate Limiting
ALLOW_TENANT_HEADER_OVERRIDE=false
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=200  # Higher limit for staging
CSRF_ENABLED=true
HELMET_ENABLED=true

# Email Configuration (use test SMTP or mailtrap)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-pass
EMAIL_FROM=Alumni Staging <no-reply@staging.alumni.example.com>

# OAuth/Social Login (use test credentials)
GOOGLE_CLIENT_ID=staging-google-client-id
GOOGLE_CLIENT_SECRET=staging-google-client-secret
GOOGLE_REDIRECT_URI=https://staging.alumni.example.com/api/auth/oauth/google/callback
LINKEDIN_CLIENT_ID=staging-linkedin-client-id
LINKEDIN_CLIENT_SECRET=staging-linkedin-client-secret
LINKEDIN_REDIRECT_URI=https://staging.alumni.example.com/api/auth/oauth/linkedin/callback

# File Upload & Storage
MAX_FILE_SIZE=10485760  # 10MB in bytes for staging
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf
STORAGE_PROVIDER=local  # Use local storage for staging
CLOUDINARY_URL=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Development & Testing
ENABLE_DEV_MOCK_MODE=false
DEBUG=alumni:*
TEST_DATABASE_URL=mongodb://staging-mongo:27017/alumni-test-staging
TEST_TIMEOUT=15000

# Monitoring
SENTRY_DSN=https://your-sentry-dsn-for-staging.ingest.sentry.io/your-project-id
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Multi-Tenancy
TENANT_COOKIE_NAME=tenant
TENANT_HEADER_NAME=X-Tenant-ID
TENANT_SUBDOMAIN_PATTERN={subdomain}.staging.alumni.example.com
TENANT_DEFAULT_BRANDING={"primaryColor":"#4f46e5","secondaryColor":"#7c3aed"}

# Frontend Variables (for Docker build)
VITE_API_URL=https://staging.alumni.example.com/api
VITE_WS_URL=wss://staging.alumni.example.com
VITE_TENANT_SUBDOMAIN=
VITE_TENANT_DOMAIN=staging.alumni.example.com
VITE_DEMO_ACCOUNTS=[{"email":"admin@staging.example.com","password":"admin123"},{"email":"user@staging.example.com","password":"user123"}]
VITE_DEBUG=true
VITE_ENABLE_MOCK_API=false

# Docker Compose Specific
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=staging-mongo-password-change-this
MONGO_HOST=staging-mongo
MONGO_PORT=27017

# Traefik Configuration (for staging)
TRAEFIK_TAG=staging
TRAEFIK_DOMAIN=staging.alumni.example.com
TRAEFIK_ENTRYPOINT_WEB=web
TRAEFIK_ENTRYPOINT_WEB_SECURE=websecure
TRAEFIK_CERTRESOLVER=stagingresolver

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=40000