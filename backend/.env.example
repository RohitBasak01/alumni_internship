# Backend Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/alumni-network
CENTRAL_MONGODB_URI=mongodb://127.0.0.1:27017/alumni-network
TENANT_MONGODB_BASE_URI=
TENANT_DATABASE_MODE=shared
DEFAULT_TENANT_ISOLATION_MODE=shared

# JWT & Authentication
JWT_SECRET=change-this-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
AUTH_COOKIE_DOMAIN=

# Application URLs
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Security & Rate Limiting
ALLOW_TENANT_HEADER_OVERRIDE=true
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
CSRF_ENABLED=true
HELMET_ENABLED=true

# Email Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Alumni Network <no-reply@alumninetwork.local>

# OAuth/Social Login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/oauth/google/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/auth/oauth/linkedin/callback

# File Upload & Storage
MAX_FILE_SIZE=5242880  # 5MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf
STORAGE_PROVIDER=local  # local, cloudinary, s3-compatible
CLOUDINARY_URL=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Development & Testing
ENABLE_DEV_MOCK_MODE=false
DEBUG=
TEST_DATABASE_URL=
TEST_TIMEOUT=10000

# Monitoring (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Multi-Tenancy
TENANT_COOKIE_NAME=tenant
TENANT_HEADER_NAME=X-Tenant-ID
TENANT_SUBDOMAIN_PATTERN={subdomain}.alumni.local
TENANT_DEFAULT_BRANDING=
