# Production Environment Variables
# Copy this file to .env.production and fill in the values

# MongoDB Configuration
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change-this-to-a-strong-password
MONGO_HOST=mongodb
MONGO_PORT=27017

# JWT Configuration
JWT_SECRET=change-this-to-a-very-strong-secret-key-at-least-32-characters

# Application URLs
CLIENT_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Backend API Configuration
PORT=5000
NODE_ENV=production
LOG_LEVEL=info

# Frontend Configuration
VITE_API_URL=https://your-domain.com/api
VITE_WS_URL=wss://your-domain.com

# Email Configuration (for production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@your-domain.com

# Sentry Error Tracking (optional)
SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/your-project-id
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.05

# File Upload Configuration
MAX_FILE_SIZE=5242880 # 5MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Security
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Grafana (optional)
GRAFANA_ADMIN_PASSWORD=change-this-to-strong-password